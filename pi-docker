#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="pi-sandbox"
PI_CONFIG_DIR="${HOME}/.pi/agent"
PI_EXTENSIONS_DIR="${PI_EXTENSIONS_DIR:-${HOME}/pi-extensions}"
PI_SKILLS_DIR="${PI_SKILLS_DIR:-${HOME}/pi-skills}"

usage() {
    cat <<'USAGE'
Usage: pi-docker [OPTIONS] [extra-path ...]

Run the PI coding agent in a sandboxed Docker container.

Options:
  --login       Start in OAuth login mode (uses --network host)
  --build       Build the Docker image before running
  --tools LIST  Mount host tools into container (comma-separated, e.g. python,ghdl)
  --help        Show this help message

Arguments:
  extra-path    Additional host directories to mount under /repos/<basename>

Environment:
  PI_EXTENSIONS_DIR   Extensions directory (default: ~/pi-extensions)
  PI_SKILLS_DIR       Skills directory (default: ~/Documents/10-repos/11-gitRepo/my-skills/skills)

Examples:
  pi-docker                          # Run in current directory
  pi-docker ~/other-repo             # Mount extra repo under /repos/other-repo
  pi-docker --login                  # OAuth login to Anthropic, etc.
  pi-docker --build                  # Rebuild image, then run
  pi-docker --tools python,ghdl      # Run with host tools mounted
USAGE
    exit 0
}

# Parse flags
LOGIN_MODE=false
BUILD_FIRST=false
EXTRA_PATHS=()
PI_ARGS=()
PARSING_PI_ARGS=false
TOOLS_LIST=""

while [ $# -gt 0 ]; do
    if [ "$PARSING_PI_ARGS" = true ]; then
        PI_ARGS+=("$1")
        shift
        continue
    fi
    case "$1" in
        --login)
            LOGIN_MODE=true
            ;;
        --build)
            BUILD_FIRST=true
            ;;
        --tools)
            shift
            TOOLS_LIST="${1:-}"
            if [ -z "$TOOLS_LIST" ]; then
                echo "Error: --tools requires a comma-separated list of tool names"
                exit 1
            fi
            ;;
        --help)
            usage
            ;;
        --)
            PARSING_PI_ARGS=true
            ;;
        -*)
            PI_ARGS+=("$1")
            ;;
        *)
            EXTRA_PATHS+=("$1")
            ;;
    esac
    shift
done

# Build if requested
if [ "$BUILD_FIRST" = true ]; then
    SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
    echo "Building ${IMAGE_NAME}..."
    docker build -t "${IMAGE_NAME}" "${SCRIPT_DIR}"
fi

# Check image exists
if ! docker image inspect "${IMAGE_NAME}" &>/dev/null; then
    echo "Error: Docker image '${IMAGE_NAME}' not found. Run with --build first."
    exit 1
fi

# Build docker run command
DOCKER_ARGS=(
    docker run
    --rm
    -it
    --name "pi-sandbox-$$"
    -e "TERM=${TERM:-xterm-256color}"
    -w /workspace
    -v "$(pwd):/workspace"
)

# Mount PI config directory (read-write for auth tokens and sessions)
if [ -d "${PI_CONFIG_DIR}" ]; then
    DOCKER_ARGS+=(-v "${PI_CONFIG_DIR}:/home/pi/.pi/agent")
fi

# Mount skills directory (read-write, resolves host symlink)
if [ -d "${PI_SKILLS_DIR}" ]; then
    DOCKER_ARGS+=(-v "${PI_SKILLS_DIR}:/home/pi/.pi/agent/skills")
fi

# Mount extensions directory (read-write)
if [ -d "${PI_EXTENSIONS_DIR}" ]; then
    DOCKER_ARGS+=(-v "${PI_EXTENSIONS_DIR}:/home/pi/.pi/agent/extensions")
fi

# Mount extra paths under /repos/<basename>
for extra in "${EXTRA_PATHS[@]}"; do
    abs_path="$(cd "$extra" && pwd)"
    basename="$(basename "$abs_path")"
    DOCKER_ARGS+=(-v "${abs_path}:/repos/${basename}")
done

if [ "$LOGIN_MODE" = true ]; then
    # Login mode: use host network for OAuth callback
    DOCKER_ARGS+=(
        --network host
        "${IMAGE_NAME}"
    )
else
    # Normal mode: sandboxed network with host.docker.internal
    DOCKER_ARGS+=(
        --cap-drop=ALL
        --security-opt=no-new-privileges
        --read-only
        --tmpfs /tmp:rw,noexec,nosuid,size=256m
        -v pi-sandbox-npm-global:/home/pi/.npm-global
        -v pi-sandbox-npm-cache:/home/pi/.npm
        --tmpfs /home/pi/.cache:rw,nosuid,size=256m,uid=1000,gid=1000
        --add-host=host.docker.internal:host-gateway
        "${IMAGE_NAME}"
    )
fi

# Append any PI arguments
if [ ${#PI_ARGS[@]} -gt 0 ]; then
    DOCKER_ARGS+=("${PI_ARGS[@]}")
fi

exec "${DOCKER_ARGS[@]}"
