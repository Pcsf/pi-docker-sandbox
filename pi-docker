#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="pi-sandbox"
PI_CONFIG_DIR="${HOME}/.pi/agent"
PI_EXTENSIONS_DIR="${PI_EXTENSIONS_DIR:-${HOME}/pi-extensions}"
PI_SKILLS_DIR="${PI_SKILLS_DIR:-${HOME}/pi-skills}"

usage() {
    cat <<'USAGE'
Usage: pi-docker [OPTIONS] [extra-path ...]

Run the PI coding agent in a sandboxed Docker container.

Options:
  --login       Start in OAuth login mode (uses --network host, no security)
  --local       Use host network for local LLM access (keeps security hardening)
  --build       Build the Docker image before running
  --tools LIST  Mount host tools into container (comma-separated, e.g. python,ghdl)
  --help        Show this help message

Arguments:
  extra-path    Additional host directories to mount under /repos/<basename>

Environment:
  PI_EXTENSIONS_DIR   Extensions directory (default: ~/pi-extensions)
  PI_SKILLS_DIR       Skills directory (default: ~/Documents/10-repos/11-gitRepo/my-skills/skills)

Examples:
  pi-docker                          # Run in current directory
  pi-docker ~/other-repo             # Mount extra repo under /repos/other-repo
  pi-docker --login                  # OAuth login to Anthropic, etc.
  pi-docker --build                  # Rebuild image, then run
  pi-docker --tools python,ghdl      # Run with host tools mounted
  pi-docker --local                   # Use host network for local LLMs
  pi-docker --local --tools python    # Combine local LLM + host tools
USAGE
    exit 0
}

# Is the given SONAME a glibc-family library? These must NOT be exposed to
# kernel-exec'd child processes via LD_LIBRARY_PATH — mixing host glibc with
# the container's dynamic linker causes GLIBC_PRIVATE symbol crashes. The
# wrapper still reaches them through --library-path /opt/host-tools/host-usr/lib.
is_glibc_lib() {
    case "$1" in
        libc.so.*|libm.so.*|libpthread.so.*|libdl.so.*|librt.so.*) return 0 ;;
        libresolv.so.*|libnsl.so.*|libutil.so.*|libcrypt.so.*) return 0 ;;
        libBrokenLocale.so.*|libanl.so.*|libthread_db.so.*) return 0 ;;
        # ld-linux is intentionally NOT excluded: entrypoint.sh looks for it
        # at /opt/host-tools/lib/ld-linux-*.so.* to generate tool wrappers.
        # It's safe in LD_LIBRARY_PATH — kernel picks the linker from
        # PT_INTERP, not from LD_LIBRARY_PATH.
        *) return 1 ;;
    esac
}

# Is the given path a standard system library directory? Mounting these would
# overlay the container's own libs (libc, libstdc++) and break the container.
is_system_lib_dir() {
    case "$1" in
        /lib|/lib64|/lib32|/usr/lib|/usr/lib64|/usr/lib32) return 0 ;;
        /lib/x86_64-linux-gnu|/usr/lib/x86_64-linux-gnu) return 0 ;;
        /lib/aarch64-linux-gnu|/usr/lib/aarch64-linux-gnu) return 0 ;;
        *) return 1 ;;
    esac
}

# Extract RPATH/RUNPATH entries from an ELF binary (one dir per line).
# Expands $ORIGIN to the binary's directory. Skips nonexistent paths.
# Silently returns nothing if readelf is unavailable.
collect_elf_rpaths() {
    local bin="$1"
    command -v readelf >/dev/null 2>&1 || return 0
    local bin_dir rpath_lines
    bin_dir="$(dirname "$bin")"
    # Capture first so a no-match grep can't trip pipefail in the caller.
    rpath_lines="$(readelf -d "$bin" 2>/dev/null | grep -E '\(R(UN)?PATH\)' || true)"
    [ -z "$rpath_lines" ] && return 0
    echo "$rpath_lines" | sed -E 's/.*\[([^]]*)\].*/\1/' | tr ':' '\n' | \
        while read -r p; do
            [ -z "$p" ] && continue
            p="${p//\$ORIGIN/$bin_dir}"
            p="${p//\$\{ORIGIN\}/$bin_dir}"
            [ -d "$p" ] && readlink -f "$p"
        done
    return 0
}

# Collect shared library info for an ELF binary.
# Emits "NEEDED|RESOLVED" pairs — NEEDED is the DT_NEEDED/SONAME-style name the
# dynamic linker searches for (e.g. libfreetype.so.6); RESOLVED is the real file
# on disk (e.g. /usr/lib/libfreetype.so.6.20.6). Callers mount RESOLVED at a
# path named NEEDED so the linker finds it via LD_LIBRARY_PATH/RPATH search.
# Skips virtual libraries (vdso, linux-gate).
collect_elf_libs() {
    local elf_path="$1"
    ldd "$elf_path" 2>/dev/null | while read -r line; do
        case "$line" in *linux-vdso*|*linux-gate*) continue ;; esac
        local needed="" lib_path=""
        if echo "$line" | grep -qE "=> /.+ \(0x"; then
            needed="$(echo "$line" | awk '{print $1}')"
            # Some ldd lines print absolute-path NEEDED (ld-linux); basename them.
            case "$needed" in /*) needed="$(basename "$needed")" ;; esac
            lib_path="$(echo "$line" | sed -E 's/.*=> (\/[^ ]+) \(0x.*/\1/')"
        elif echo "$line" | grep -qE "^\s*/"; then
            lib_path="$(echo "$line" | sed -E 's/^\s*(\/[^ ]+).*/\1/')"
            needed="$(basename "$lib_path")"
        fi
        if [ -n "$lib_path" ] && [ -f "$lib_path" ]; then
            echo "${needed}|$(readlink -f "$lib_path")"
        fi
    done
}

# Detect runtime directories a tool needs beyond its binary and .so deps.
# Output: one "DIR:<path>" line per directory to mount at its original path.
detect_runtime_dirs() {
    local real_path="$1"
    local libs="$2"
    # Python: if it links libpythonX.Y, mount the stdlib directory
    local pyver
    pyver="$(echo "$libs" | grep -oP 'libpython\K[0-9]+\.[0-9]+' | head -1)" || true
    if [ -n "$pyver" ]; then
        local pylib="/usr/lib/python${pyver}"
        [ -d "$pylib" ] && echo "DIR:${pylib}"
        local pydynload="/usr/lib/python${pyver}/lib-dynload"
        [ -d "$pydynload" ] && echo "DIR:${pydynload}"
    fi
}

# Resolve a host tool into: its real binary path, library deps, and runtime dirs.
# Output format:
#   BIN:<real_binary_path>  — the tool binary
#   LIB:<real_lib_path>     — shared library dependency
#   DIR:<dir_path>          — runtime directory to mount at original path
resolve_tool_deps() {
    local tool_name="$1"
    local binary_path

    binary_path="$(command -v "$tool_name" 2>/dev/null)" || true
    if [ -z "$binary_path" ]; then
        echo "Warning: tool '${tool_name}' not found on host, skipping" >&2
        return
    fi

    local real_path
    real_path="$(readlink -f "$binary_path")"

    if [ "$(head -c4 "$real_path" 2>/dev/null | od -An -tx1 | tr -d ' \n')" = "7f454c46" ]; then
        echo "BIN:${real_path}"
        local libs
        libs="$(collect_elf_libs "$real_path")"
        echo "$libs" | while IFS='|' read -r lib_needed lib_path; do
            [ -z "$lib_path" ] && continue
            # LIB emission carries both names: NEEDED is the dynamic-linker
            # search key (libfreetype.so.6), path is the real file.
            echo "LIB:${lib_needed}|${lib_path}"
            # If the lib lives in a tool-specific subdir (not a system-wide
            # lib dir), mount that dir at its literal path. Needed for libs
            # referenced via RPATH when the binary is exec'd by the kernel
            # without going through our wrapper (e.g. octave spawning
            # /usr/bin/octave-cli-*).
            lib_dir="$(dirname "$lib_path")"
            is_system_lib_dir "$lib_dir" || echo "DIR:${lib_dir}"
        done
        detect_runtime_dirs "$real_path" "$libs"
        # Mount RPATH/RUNPATH dirs at their literal host paths. Needed because
        # the kernel-invoked linker on execve'd children doesn't know about our
        # isolated /opt/host-tools/lib — it only consults the binary's embedded
        # RPATH, which points at host-specific subdirs like /usr/lib64/octave/*.
        collect_elf_rpaths "$real_path" | while read -r rp; do
            [ -n "$rp" ] && echo "DIR:${rp}"
        done
        # Always mount the real binary at its literal host path — when the tool
        # is a symlink (e.g. /usr/bin/octave -> octave-cli-11.1.0) internal
        # execve calls use the resolved absolute path, which wouldn't exist in
        # the container otherwise.
        echo "SIBLING:${real_path}"
        # Detect sibling binaries (same dir, shared prefix with the tool name)
        # that the tool may exec via hardcoded absolute paths.
        local bindir
        bindir="$(dirname "$binary_path")"
        for sibling in "$bindir/${tool_name}"-* "$bindir/${tool_name}"*; do
            [ -e "$sibling" ] || continue
            [ "$sibling" = "$binary_path" ] && continue
            [ "$sibling" = "$real_path" ] && continue
            echo "SIBLING:${sibling}"
        done
    else
        # Script — resolve shebang interpreter (one level only)
        echo "BIN:${real_path}"
        local shebang
        shebang="$(head -c256 "$real_path" 2>/dev/null | head -1)"
        if [[ "$shebang" == "#!"* ]]; then
            local interp
            interp="$(echo "$shebang" | sed -E 's/^#!\s*//' | awk '{print $1}')"
            # Handle /usr/bin/env by resolving the actual command
            if [ "$(basename "$interp")" = "env" ]; then
                local env_tool
                env_tool="$(echo "$shebang" | sed -E 's/^#!\s*//' | awk '{print $2}')"
                interp="$(command -v "$env_tool" 2>/dev/null)" || true
            fi
            if [ -n "$interp" ]; then
                local real_interp
                real_interp="$(readlink -f "$interp")"
                if [ "$(head -c4 "$real_interp" 2>/dev/null | od -An -tx1 | tr -d ' \n')" = "7f454c46" ]; then
                    echo "LIB:${real_interp}"
                    local libs
                    libs="$(collect_elf_libs "$real_interp")"
                    echo "$libs" | while read -r lib; do
                        [ -n "$lib" ] && echo "LIB:${lib}"
                    done
                    detect_runtime_dirs "$real_interp" "$libs"
                fi
            fi
        fi
    fi
}

# Parse flags
LOGIN_MODE=false
LOCAL_MODE=false
BUILD_FIRST=false
EXTRA_PATHS=()
PI_ARGS=()
PARSING_PI_ARGS=false
TOOLS_LIST=""

while [ $# -gt 0 ]; do
    if [ "$PARSING_PI_ARGS" = true ]; then
        PI_ARGS+=("$1")
        shift
        continue
    fi
    case "$1" in
        --login)
            LOGIN_MODE=true
            ;;
        --local)
            LOCAL_MODE=true
            ;;
        --build)
            BUILD_FIRST=true
            ;;
        --tools)
            shift
            TOOLS_LIST="${1:-}"
            if [ -z "$TOOLS_LIST" ]; then
                echo "Error: --tools requires a comma-separated list of tool names"
                exit 1
            fi
            ;;
        --help)
            usage
            ;;
        --)
            PARSING_PI_ARGS=true
            ;;
        -*)
            PI_ARGS+=("$1")
            ;;
        *)
            EXTRA_PATHS+=("$1")
            ;;
    esac
    shift
done

# Build if requested
if [ "$BUILD_FIRST" = true ]; then
    SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
    echo "Building ${IMAGE_NAME}..."
    docker build -t "${IMAGE_NAME}" "${SCRIPT_DIR}"
fi

# Check image exists
if ! docker image inspect "${IMAGE_NAME}" &>/dev/null; then
    echo "Error: Docker image '${IMAGE_NAME}' not found. Run with --build first."
    exit 1
fi

# Build docker run command
DOCKER_ARGS=(
    docker run
    --rm
    -it
    --name "pi-sandbox-$$"
    -e "TERM=${TERM:-xterm-256color}"
    -w /workspace
    -v "$(pwd):/workspace"
)

# Mount PI config directory (read-write for auth tokens and sessions)
if [ -d "${PI_CONFIG_DIR}" ]; then
    DOCKER_ARGS+=(-v "${PI_CONFIG_DIR}:/home/pi/.pi/agent")
fi

# Mount skills directory (read-write, resolves host symlink)
if [ -d "${PI_SKILLS_DIR}" ]; then
    DOCKER_ARGS+=(-v "${PI_SKILLS_DIR}:/home/pi/.pi/agent/skills")
fi

# Mount extensions directory (read-write)
if [ -d "${PI_EXTENSIONS_DIR}" ]; then
    DOCKER_ARGS+=(-v "${PI_EXTENSIONS_DIR}:/home/pi/.pi/agent/extensions")
fi

# Mount extra paths under /repos/<basename>
for extra in "${EXTRA_PATHS[@]}"; do
    abs_path="$(cd "$extra" && pwd)"
    basename="$(basename "$abs_path")"
    DOCKER_ARGS+=(-v "${abs_path}:/repos/${basename}")
done

# Mount host tools and their dependencies into isolated /opt/host-tools/
# Binaries go to /opt/host-tools/real/<name>, libs to /opt/host-tools/lib/.
# The entrypoint creates wrapper scripts that invoke the host's dynamic linker
# with --library-path so host and container libraries never mix.
if [ -n "$TOOLS_LIST" ]; then
    declare -A LIBS_SEEN=()
    declare -A DIRS_SEEN=()
    TOOL_NAMES=()
    IFS=',' read -ra TOOLS_ARRAY <<< "$TOOLS_LIST"
    for tool in "${TOOLS_ARRAY[@]}"; do
        tool="${tool## }"; tool="${tool%% }"
        [ -z "$tool" ] && continue
        TOOL_NAMES+=("$tool")
        while IFS= read -r entry; do
            case "$entry" in
                BIN:*)
                    local_path="${entry#BIN:}"
                    DOCKER_ARGS+=(-v "${local_path}:/opt/host-tools/real/${tool}:ro")
                    ;;
                LIB:*)
                    lib_entry="${entry#LIB:}"
                    lib_needed="${lib_entry%%|*}"
                    local_path="${lib_entry#*|}"
                    [ "$lib_needed" = "$local_path" ] && lib_needed="$(basename "$local_path")"
                    # Skip glibc-family libs: exposing them to children via
                    # LD_LIBRARY_PATH would crash the container's ld-linker.
                    # The wrapper still finds them via /opt/host-tools/host-usr/lib.
                    is_glibc_lib "$lib_needed" && continue
                    if [ -z "${LIBS_SEEN[$local_path]+x}" ]; then
                        LIBS_SEEN["$local_path"]=1
                        DOCKER_ARGS+=(-v "${local_path}:/opt/host-tools/lib/${lib_needed}:ro")
                    fi
                    ;;
                DIR:*)
                    local_path="${entry#DIR:}"
                    if [ -z "${DIRS_SEEN[$local_path]+x}" ]; then
                        DIRS_SEEN["$local_path"]=1
                        DOCKER_ARGS+=(-v "${local_path}:${local_path}:ro")
                    fi
                    ;;
                SIBLING:*)
                    local_path="${entry#SIBLING:}"
                    if [ -z "${LIBS_SEEN[$local_path]+x}" ]; then
                        LIBS_SEEN["$local_path"]=1
                        # Bind-mount at the host's literal path so hardcoded
                        # execve(/usr/bin/<sibling>) calls resolve inside the
                        # container. Also pull its transitive lib deps and
                        # RPATH dirs (needed when the sibling is exec'd
                        # directly by the kernel, bypassing our wrapper).
                        DOCKER_ARGS+=(-v "${local_path}:${local_path}:ro")
                        while IFS='|' read -r sib_needed sib_lib; do
                            [ -z "$sib_lib" ] && continue
                            [ -z "$sib_needed" ] && sib_needed="$(basename "$sib_lib")"
                            if ! is_glibc_lib "$sib_needed" \
                                && [ -z "${LIBS_SEEN[$sib_lib]+x}" ]; then
                                LIBS_SEEN["$sib_lib"]=1
                                DOCKER_ARGS+=(-v "${sib_lib}:/opt/host-tools/lib/${sib_needed}:ro")
                            fi
                            sib_lib_dir="$(dirname "$sib_lib")"
                            if ! is_system_lib_dir "$sib_lib_dir" \
                                && [ -z "${DIRS_SEEN[$sib_lib_dir]+x}" ]; then
                                DIRS_SEEN["$sib_lib_dir"]=1
                                DOCKER_ARGS+=(-v "${sib_lib_dir}:${sib_lib_dir}:ro")
                            fi
                        done < <(collect_elf_libs "$local_path")
                        while IFS= read -r rp; do
                            [ -z "$rp" ] && continue
                            if [ -z "${DIRS_SEEN[$rp]+x}" ]; then
                                DIRS_SEEN["$rp"]=1
                                DOCKER_ARGS+=(-v "${rp}:${rp}:ro")
                            fi
                        done < <(collect_elf_rpaths "$local_path")
                    fi
                    ;;
            esac
        done < <(resolve_tool_deps "$tool")
    done
    # Mount host /usr read-only under /opt/host-tools/host-usr/ (excluding
    # /usr/local and /usr/src to avoid exposing user scripts with hardcoded
    # secrets). Covers dlopen'd libs, runtime data (fonts, themes, .m files,
    # configs) that ldd cannot discover. Does NOT overlay the container's own
    # /usr, so sibling binaries at hardcoded /usr/bin/<name> paths still need
    # SIBLING: detection above.
    for entry in /usr/*; do
        [ -d "$entry" ] || continue
        name="$(basename "$entry")"
        case "$name" in local|src) continue ;; esac
        DOCKER_ARGS+=(-v "${entry}:/opt/host-tools/host-usr/${name}:ro")
    done
    # Writable tmpfs for wrapper scripts created by entrypoint
    DOCKER_ARGS+=(--tmpfs /opt/host-tools/bin:rw,exec,nosuid,size=1m,uid=1000,gid=1000)
    # Tell entrypoint which tools to wrap
    DOCKER_ARGS+=(-e "PI_HOST_TOOLS=$(IFS=,; echo "${TOOL_NAMES[*]}")")
fi

# Security hardening (applied in all modes except login)
if [ "$LOGIN_MODE" != true ]; then
    DOCKER_ARGS+=(
        --cap-drop=ALL
        --security-opt=no-new-privileges
        --read-only
        --tmpfs /tmp:rw,noexec,nosuid,size=256m
        -v pi-sandbox-npm-global:/home/pi/.npm-global
        -v pi-sandbox-npm-cache:/home/pi/.npm
        --tmpfs /home/pi/.cache:rw,nosuid,size=256m,uid=1000,gid=1000
    )
fi

# Network mode
if [ "$LOGIN_MODE" = true ] || [ "$LOCAL_MODE" = true ]; then
    # Host network: needed for OAuth callbacks or local LLM access
    DOCKER_ARGS+=(--network host -e PI_HOST_NETWORK=1)
else
    # Bridge network with host.docker.internal
    DOCKER_ARGS+=(--add-host=host.docker.internal:host-gateway)
fi

DOCKER_ARGS+=("${IMAGE_NAME}")

# Append any PI arguments
if [ ${#PI_ARGS[@]} -gt 0 ]; then
    DOCKER_ARGS+=("${PI_ARGS[@]}")
fi

exec "${DOCKER_ARGS[@]}"
